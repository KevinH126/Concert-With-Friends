# Copy to `.env` and fill in. `.env` is gitignored.

# Postgres. Local docker-compose default shown; the app normalizes the driver,
# so `postgresql://...` also works (prod DATABASE_URL comes from Render).
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/concert_friends

# JWT signing key. Generate a fresh one:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me

# Ops token for POST /admin/sync. MUST be different from SECRET_KEY so a leaked
# admin token can't forge JWTs. Generate the same way as SECRET_KEY.
ADMIN_TOKEN=change-me-too

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Blank runs Ticketmaster in stub mode (genre matching testable, artist matching not).
TICKETMASTER_API_KEY=

REDIS_URL=redis://localhost:6379/0
